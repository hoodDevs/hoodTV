modules = ["nodejs-20", "python-3.12", "web", "go-1.21", "rust"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Scala Gateway"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Go Proxy"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "YouTube Music Video Service"

[[workflows.workflow]]
name = "Scala Gateway"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export PATH=$PATH:/nix/var/nix/profiles/default/bin && PORT=8000 PYTHON_URL=http://localhost:8080 RUST_URL=http://localhost:9000 GO_URL=http://localhost:8090 /nix/store/xnndv02a17ylc8yzmcqzjmj2k54bmrk5-scala-cli-1.8.0/bin/scala-cli run --server=false artifacts/scala-gateway/Gateway.scala"
waitForPort = 8000

[[workflows.workflow]]
name = "Rust CDN Health"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export PATH=$PATH:/nix/var/nix/profiles/default/bin && PORT=9000 cargo run --manifest-path artifacts/rust-health/Cargo.toml"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Go Proxy"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=$PATH:/nix/var/nix/profiles/default/bin PORT=8090 go run artifacts/go-proxy/main.go"

[[workflows.workflow]]
name = "YouTube Music Video Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/yt-service && PORT=8099 node src/index.js"
waitForPort = 8099

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8070
externalPort = 3002

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 6000

[[ports]]
localPort = 8090
externalPort = 3001

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 9000
externalPort = 9000

[[ports]]
localPort = 20820
externalPort = 3000

[[ports]]
localPort = 20821
externalPort = 3003

[[ports]]
localPort = 20822
externalPort = 5000

[[ports]]
localPort = 20823
externalPort = 5173

[nix]
channel = "stable-25_05"
