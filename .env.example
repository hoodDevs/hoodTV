# ─────────────────────────────────────────────────────────────────────────────
# hoodTV — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── TMDB (The Movie Database) ─────────────────────────────────────────────────
# Required for all movie/TV metadata, posters, and backdrop images.
# Get a free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Frontend also needs it as a Vite env var (must be prefixed with VITE_)
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# ── MovieBox Streaming (optional) ─────────────────────────────────────────────
# Used by the MovieBox streaming source. Leave empty to disable this source.
MOVIEBOX_SECRET_KEY=
MOVIEBOX_SECRET_KEY_ALT=

# ── Gifted Tech API (optional) ────────────────────────────────────────────────
# Alternative streaming source. Leave empty to skip.
# Frontend Vite variable:
VITE_GIFTED_API_KEY=
# Backend variable:
GIFTED_API_KEY=

# ── Service Ports (optional — defaults shown) ─────────────────────────────────
# PORT=8080          # Python FastAPI backend
# PORT=8090          # Go reverse proxy
# PORT=9000          # Rust CDN health checker
# PORT=8000          # Scala API gateway
# PORT=8099          # YouTube music service (Node.js)
# PORT=20820         # React/Vite frontend
